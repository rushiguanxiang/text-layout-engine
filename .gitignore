# ==============================================
#  TextLayoutEngine - 滇池拂晓版
#  工业级 Rust + WASM 排版引擎 .gitignore
# ==============================================

# WASM 构建产物（自动生成，绝不提交）
pkg/
target/
dist/
build/
output/
wasm/

# npm 依赖与锁文件（环境无关）
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# 编辑器配置与缓存
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# 日志、临时文件、测试缓存
*.log
tmp/
temp/
*.tmp

# 环境密钥、本地配置（绝对不能泄露）
.env
.env.local
.env.*.local

# 演示站静态资源缓存
.cache/
.parcel-cache/
.next/
.vercel

# 性能测试临时数据
benchmark-*.json
profile/
